{
  "name": "@wxwzl/vue-virtual-tree",
  "version": "0.1.14",
  "description": "A high-performance virtual tree component for Vue 3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./style": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "vue",
    "vue3",
    "tree",
    "virtual-scroll",
    "virtual-tree",
    "component"
  ],
  "author": "wxwzl",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wxwzl/vue-virtual-tree.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "sass-embedded": "^1.93.3",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.6.0"
  },
  "scripts": {
    "prepublish": "pnpm run build",
    "build": "vite build",
    "publish": "npm publish",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .js,.ts,.vue",
    "lint:fix": "eslint . --ext .js,.ts,.vue --fix",
    "lint:staged": "eslint --fix",
    "format:staged": "prettier --write"
  },
  "dependencies": {
    "vue": "3.4.0",
    "vue-virtual-scroller": "2.0.0-beta.9"
  }
}
